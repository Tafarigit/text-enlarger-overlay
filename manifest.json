{
  "manifest_version": 3,
  "name": "Text Enlarger Overlay",
  "version": "1.1.0",
  "description": "Resize and control text overlays on web pages for improved readability and accessibility.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_title": "Text Enlarger"
  },
  "icons": {
  "16": "icons/icon16.png",
  "32": "icons/icon32.png",
  "48": "icons/icon48.png",
  "128": "icons/icon128.png"
},
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "commands": {
    "toggle-text-enlarger": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Toggle text enlarger overlay"
    }
  }
}